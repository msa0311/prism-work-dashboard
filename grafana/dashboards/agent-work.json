{
  "uid": "prism-agent-work",
  "title": "Agent Work",
  "description": "Work performed by Prism agents, from prism-work-telemetry records (work.schema=1)",
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "Work items",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 1,
          "rawSql": "SELECT count() AS items FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND $__timeFilter(Timestamp)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Human minutes saved (est.)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          },
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 1,
          "rawSql": "SELECT sum(toFloat64OrZero(LogAttributes['work.human_minutes_saved'])) AS minutes_saved FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND $__timeFilter(Timestamp)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Time to outcome (p95)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          },
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 1,
          "rawSql": "SELECT quantile(0.95)(toFloat64OrNull(LogAttributes['work.duration_ms'])) / 1000 AS p95_seconds FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND $__timeFilter(Timestamp)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Recurrence within 24 h",
      "description": "Share of work items whose work.id was already handled in the previous 24 h \u2014 a low rate means outcomes stick.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          },
          "unit": "percentunit",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 1,
          "rawSql": "SELECT if(count() = 0, 0, countIf(prev_ts IS NOT NULL AND dateDiff('second', prev_ts, Timestamp) <= 86400) / count()) AS recurrence_rate FROM (SELECT Timestamp, lagInFrame(toNullable(Timestamp)) OVER (PARTITION BY LogAttributes['work.id'] ORDER BY Timestamp ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS prev_ts FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND LogAttributes['work.id'] != '' AND $__timeFilter(Timestamp))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Work items over time, by outcome",
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 85,
            "lineWidth": 0,
            "stacking": {
              "mode": "normal"
            },
            "barAlignment": 0
          },
          "unit": "none",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "items diagnosed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#3987e5"
                }
              },
              {
                "id": "displayName",
                "value": "diagnosed"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "items needs_human"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#c98500"
                }
              },
              {
                "id": "displayName",
                "value": "needs_human"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "items remediated"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#199e70"
                }
              },
              {
                "id": "displayName",
                "value": "remediated"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "items escalated"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d95926"
                }
              },
              {
                "id": "displayName",
                "value": "escalated"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "items no_action"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#9085e9"
                }
              },
              {
                "id": "displayName",
                "value": "no_action"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "items recovered"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#008300"
                }
              },
              {
                "id": "displayName",
                "value": "recovered"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "items false_positive"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d55181"
                }
              },
              {
                "id": "displayName",
                "value": "false_positive"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "items failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d03b3b"
                }
              },
              {
                "id": "displayName",
                "value": "failed"
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 0,
          "rawSql": "SELECT $__timeInterval(Timestamp) AS time, LogAttributes['work.outcome'] AS outcome, count() AS items FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND $__timeFilter(Timestamp) GROUP BY time, outcome ORDER BY time"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Outcome mix",
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 5
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "diagnosed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#3987e5"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "needs_human"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#c98500"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "remediated"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#199e70"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "escalated"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d95926"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "no_action"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#9085e9"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "recovered"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#008300"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "false_positive"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d55181"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d03b3b"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "showLegend": true
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": true
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 1,
          "rawSql": "SELECT LogAttributes['work.outcome'] AS outcome, count() AS items FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND $__timeFilter(Timestamp) GROUP BY outcome ORDER BY items DESC"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Time to outcome",
      "description": "From problem detection (work.detected_at) to the agent's finished work.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true
          },
          "unit": "s",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p50"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#3987e5"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "p95"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#c98500"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 0,
          "rawSql": "SELECT $__timeInterval(Timestamp) AS time, quantile(0.5)(toFloat64OrNull(LogAttributes['work.duration_ms'])) / 1000 AS p50, quantile(0.95)(toFloat64OrNull(LogAttributes['work.duration_ms'])) / 1000 AS p95 FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND $__timeFilter(Timestamp) GROUP BY time ORDER BY time"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "By severity",
      "gridPos": {
        "h": 9,
        "w": 6,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 85,
            "lineWidth": 0
          },
          "unit": "none",
          "min": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "#3987e5"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "legend": {
          "showLegend": false
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 1,
          "rawSql": "SELECT coalesce(nullIf(LogAttributes['work.severity'], ''), 'unset') AS severity, count() AS items FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND $__timeFilter(Timestamp) GROUP BY severity ORDER BY arrayFirstIndex(x -> x = severity, ['critical','high','medium','low','info','unset'])"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "By category",
      "description": "Domain class per work type (e.g. root-cause class for k8s.triage).",
      "gridPos": {
        "h": 9,
        "w": 6,
        "x": 18,
        "y": 14
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 85,
            "lineWidth": 0
          },
          "unit": "none",
          "min": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "#199e70"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "legend": {
          "showLegend": false
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 1,
          "rawSql": "SELECT coalesce(nullIf(LogAttributes['work.category'], ''), 'unknown') AS category, count() AS items FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND $__timeFilter(Timestamp) GROUP BY category ORDER BY items DESC LIMIT 12"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Human minutes saved (cumulative, est.)",
      "description": "Sum of work.human_minutes_saved. For ROI, divide by the agents' cost from the platform's usage/cost reporting for the same window.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12,
            "spanNulls": true
          },
          "unit": "none",
          "min": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "#199e70"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": false
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 0,
          "rawSql": "SELECT time, sum(minutes) OVER (ORDER BY time) AS minutes_saved FROM (SELECT $__timeInterval(Timestamp) AS time, sum(toFloat64OrZero(LogAttributes['work.human_minutes_saved'])) AS minutes FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND $__timeFilter(Timestamp) GROUP BY time ORDER BY time)"
        }
      ]
    },
    {
      "type": "table",
      "title": "Fleet \u2014 work by agent",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "prism-clickhouse"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p95 (s)"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "minutes saved"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "items",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "editorType": "sql",
          "format": 1,
          "rawSql": "SELECT coalesce(nullIf(LogAttributes['agent.name'], ''), LogAttributes['agent.id']) AS agent, count() AS items, countIf(LogAttributes['work.outcome'] IN ('escalated','needs_human','failed')) AS \"needs attention\", sum(toFloat64OrZero(LogAttributes['work.human_minutes_saved'])) AS \"minutes saved\", quantile(0.95)(toFloat64OrNull(LogAttributes['work.duration_ms'])) / 1000 AS \"p95 (s)\" FROM otel.otel_logs WHERE ServiceName = 'prism-work-telemetry' AND $__timeFilter(Timestamp) GROUP BY agent ORDER BY items DESC"
        }
      ]
    }
  ]
}
